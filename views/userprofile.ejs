<!DOCTYPE html>
<html lang="id">
<head><meta charset="UTF-8"><title>Profil <%= profileUser.username %> — CloudGG</title></head>
<body>
<%- include('navbar') %>
<style>
.profile-header {
  background:var(--bg2); border-bottom:1px solid var(--border);
  padding:2.5rem 0; position:relative; overflow:hidden;
}
.profile-header::before {
  content:''; position:absolute; inset:0;
  background: radial-gradient(ellipse 80% 100% at 100% 50%, rgba(139,92,246,.12), transparent);
  pointer-events:none;
}
.profile-header-inner { display:flex; align-items:center; gap:2rem; position:relative; }
@media(max-width:600px){ .profile-header-inner{flex-direction:column;text-align:center;} }
.profile-avatar { width:110px; height:110px; border-radius:50%; object-fit:cover; border:3px solid var(--purple); box-shadow:0 0 25px rgba(139,92,246,.4); flex-shrink:0; }
.profile-name { font-family:var(--font-head); font-size:1.6rem; font-weight:700; letter-spacing:1px; }
.profile-bio { color:var(--muted); margin:.5rem 0; font-size:.92rem; max-width:500px; line-height:1.6; }
.profile-stats { display:flex; gap:1.5rem; margin-top:.75rem; }
.stat { text-align:center; }
.stat-val { font-family:var(--font-head); font-size:1.2rem; font-weight:700; color:var(--cyan); }
.stat-key { font-size:.75rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; }

.collection-section { padding:2.5rem 0; }
.collection-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:1rem; margin-top:1.25rem; }
.coll-card { background:var(--card); border:1px solid var(--border); border-radius:10px; overflow:hidden; transition:all .2s; }
.coll-card:hover { border-color:rgba(139,92,246,.4); transform:translateY(-3px); }
.coll-img { width:100%; height:95px; object-fit:cover; }
.coll-body { padding:.65rem .75rem; }
.coll-title { font-weight:700; font-size:.83rem; margin-bottom:.3rem; }
.coll-stars { color:var(--yellow); font-size:.8rem; }
</style>

<!-- PROFILE HEADER -->
<div class="profile-header">
  <div class="container">
    <div class="profile-header-inner">
      <img src="<%= profileUser.UserDetail?.imageUrl || 'https://randomuser.me/api/portraits/lego/1.jpg' %>"
        class="profile-avatar" alt="<%= profileUser.username %>">
      <div>
        <div class="profile-name"><%= profileUser.username %></div>
        <div style="margin:.4rem 0">
          <span class="g-badge <%= profileUser.role === 'admin' ? 'badge-red' : 'badge-purple' %>">
            <%= profileUser.role.toUpperCase() %>
          </span>
        </div>
        <p class="profile-bio"><%= profileUser.UserDetail?.description || 'Belum ada bio.' %></p>
        <div class="profile-stats">
          <div class="stat">
            <div class="stat-val"><%= profileUser.Games?.length || 0 %></div>
            <div class="stat-key">Game</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- COLLECTION -->
<div class="collection-section">
  <div class="container">
    <div class="section-label">🎮 Koleksi Game</div>
    <% if (!profileUser.Games || profileUser.Games.length === 0) { %>
      <div style="color:var(--muted);padding:2rem 0">User ini belum memiliki game.</div>
    <% } else { %>
      <div class="collection-grid">
        <% profileUser.Games.forEach(game => { %>
          <a href="/games/<%= game.id %>" class="coll-card" style="text-decoration:none;color:inherit">
            <img src="<%= game.imageUrl %>" class="coll-img" alt="<%= game.title %>"
              onerror="this.src='https://placehold.co/300x150/12121f/444?text=?'">
            <div class="coll-body">
              <div class="coll-title"><%= game.title %></div>
              <span class="g-badge badge-cyan" style="font-size:.7rem"><%= game.Genre?.title || '' %></span>
              <% if (game.GameUser?.rating) { %>
                <div class="coll-stars"><%= '★'.repeat(game.GameUser.rating) %></div>
              <% } %>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>
</body></html>
